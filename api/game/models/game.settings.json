{
  "kind": "collectionType",
  "collectionName": "games",
  "info": {
    "name": "Game",
    "description": ""
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nome",
      "required": true
    },
    "breve_descricao": {
      "type": "text",
      "required": true,
      "unique": false,
      "maxLength": 160
    },
    "descricao": {
      "type": "richtext",
      "required": true
    },
    "preco": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "data_lancamento": {
      "type": "date"
    },
    "avaliacao": {
      "type": "enumeration",
      "enum": [
        "Gratuito",
        "pegi3",
        "pegi7",
        "pegi12",
        "pegi16",
        "pegi18"
      ]
    },
    "background_jogo": {
      "model": "file",
      "via": "related",
      "allowedTypes": [
        "images",
        "videos"
      ],
      "plugin": "upload",
      "required": false,
      "pluginOptions": {}
    },
    "galeria": {
      "collection": "file",
      "via": "related",
      "allowedTypes": [
        "images",
        "videos"
      ],
      "plugin": "upload",
      "required": false,
      "pluginOptions": {}
    },
    "categorias": {
      "collection": "categoria",
      "via": "games",
      "dominant": true
    },
    "desenvolvedoras": {
      "collection": "developer",
      "via": "games",
      "dominant": true
    },
    "plataformas": {
      "collection": "plataforma",
      "via": "games",
      "dominant": true
    },
    "publicado": {
      "model": "publicado",
      "via": "games"
    }
  }
}
